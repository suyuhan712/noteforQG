<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration
        PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>
    <!-- 环境配置：连接数据库的信息 -->
    <environments default="development">
        <environment id="development">
            <transactionManager type="JDBC"/>
            <dataSource type="POOLED">
                <!-- MySQL 8.0+ 驱动类 -->
                <property name="driver" value="com.mysql.cj.jdbc.Driver"/>
                <!-- 数据库连接URL：localhost:3306/你的数据库名，useSSL=false避免警告 -->
                <property name="url" value="jdbc:mysql://localhost:3306/StudentRepair?useSSL=false&amp;serverTimezone=UTC"/>
                <property name="username" value="root"/> <!-- 你的MySQL用户名 -->
                <property name="password" value="suyuhan666666"/> <!-- 你的MySQL密码 -->
            </dataSource>
        </environment>
    </environments>
    <!-- 映射器：指定SQL映射文件的位置 -->
    <mappers>
        <mapper resource="mappers/UserMapper.xml"/>
        <mapper resource="mappers/RepairOrderMapper.xml"/>
    </mappers>
</configuration>